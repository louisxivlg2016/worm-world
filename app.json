{
  "expo": {
    "name": "Worm World",
    "slug": "worm-world",
    "version": "1.0.0",
    "scheme": "wormworld",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wormworld.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0a0a2e"
      },
      "package": "com.wormworld.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-screen-orientation",
      "expo-notifications",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0a0a2e"
        }
      ]
    ]
  }
}
