{
  "name": "worm-world",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bunx vite",
    "build": "bunx vite build",
    "build:crazygames": "bash scripts/build-platform.sh crazygames",
    "build:poki": "bash scripts/build-platform.sh poki",
    "build:newgrounds": "bash scripts/build-platform.sh newgrounds",
    "build:itchio": "bash scripts/build-platform.sh itchio",
    "build:steam": "bash scripts/build-platform.sh steam",
