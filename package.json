  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "effect": "^3.19.16",
    "i18next": "^25.8.6",
    "react": "^19",
    "react-dom": "^19",
    "react-i18next": "^16.5.4",
    "trystero": "^0.22.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5",
    "babel-plugin-react-compiler": "^1",
    "vite": "^7",
    "vite-plugin-javascript-obfuscator": "^3"
  }
