{
  "name": "worm-world",
  "version": "1.0.0",
  "type": "module",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "dev": "bunx vite",
    "build": "bunx vite build",
    "build:crazygames": "bash scripts/build-platform.sh crazygames",
    "build:poki": "bash scripts/build-platform.sh poki",
    "build:newgrounds": "bash scripts/build-platform.sh newgrounds",
    "build:itchio": "bash scripts/build-platform.sh itchio",
    "build:steam": "bash scripts/build-platform.sh steam",
    "build:all": "for p in crazygames poki newgrounds itchio steam; do bash scripts/build-platform.sh $p; done",
    "postinstall": "bash scripts/patch-trystero.sh"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.63",
    "@expo-google-fonts/bungee": "^0.4.1",
    "@expo-google-fonts/fredoka": "^0.4.1",
    "@expo/metro-runtime": "^55.0.6",
    "ai": "^6.0.137",
    "effect": "^3.19.16",
    "expo": "^55.0.8",
    "expo-av": "^16.0.8",
    "expo-constants": "~55.0.9",
    "expo-font": "^55.0.4",
    "expo-haptics": "^55.0.9",
    "expo-keep-awake": "^55.0.4",
    "expo-linking": "~55.0.8",
    "expo-notifications": "^55.0.13",
    "expo-router": "^55.0.7",
    "expo-screen-orientation": "^55.0.9",
    "expo-sharing": "^55.0.14",
    "expo-splash-screen": "^55.0.12",
    "i18next": "^25.8.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^16.5.4",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.7.2",
    "smithers-orchestrator": "^0.12.7",
    "spacetimedb": "^2.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "~19.1.7",
    "@vitejs/plugin-react": "^5",
    "babel-plugin-react-compiler": "^1",
    "babel-preset-expo": "^55.0.12",
    "typescript": "~5.9.2",
    "vite": "^7",
    "vite-plugin-javascript-obfuscator": "^3"
  },
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": ["expo-av"]
      }
    }
